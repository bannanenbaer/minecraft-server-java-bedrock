# =============================================================
# Minecraft Server – Konfiguration
# =============================================================
# Nur diese Datei muss angepasst werden.
# Änderungen werden beim nächsten Container-Start übernommen.
# =============================================================


# -------------------------------------------------------------
# VERSION
# -------------------------------------------------------------
# "LATEST"  = immer die neueste stabile Version
# Oder eine spezifische Version, z.B.: 1.21.4  /  1.20.1
# -------------------------------------------------------------
VERSION=LATEST


# -------------------------------------------------------------
# SERVER-TYP
# -------------------------------------------------------------
# PAPER    = empfohlen – beste Performance, unterstützt Plugins
# VANILLA  = offizieller Vanilla-Server (keine Plugins/Mods)
# FABRIC   = für Fabric-Mods  → unten MODRINTH_PROJECTS anpassen
# FORGE    = für Forge-Mods   → unten MODRINTH_PROJECTS anpassen
# -------------------------------------------------------------
TYPE=PAPER


# -------------------------------------------------------------
# ARBEITSSPEICHER
# -------------------------------------------------------------
# Mindestens 2G empfohlen; für viele Spieler oder Mods: 4G+
# Beispiele: 1G  2G  4G  8G
# -------------------------------------------------------------
MEMORY=2G


# -------------------------------------------------------------
# ZEITZONE
# -------------------------------------------------------------
TZ=Europe/Berlin


# =============================================================
# PLUGINS / MODS  (Modrinth)
# =============================================================
# GeyserMC ("geyser") und Floodgate ("floodgate") sind IMMER
# enthalten – sie erlauben Bedrock-Spielern dem Java-Server
# beizutreten, ohne etwas zu ändern.
#
# Weitere Plugins einfach mit Komma anhängen:
#   MODRINTH_PROJECTS=geyser,floodgate,worldedit,essentialsx
#
# Modrinth-Slug findest du in der URL:
#   https://modrinth.com/plugin/<SLUG-HIER>
#
# Hinweis für FABRIC:  "geyser"  →  "geyser-fabric"   ersetzen
#                      "floodgate" → "floodgate-fabric" ersetzen
# Hinweis für FORGE:   GeyserMC ist als FORGE-Mod nicht via
#                      Modrinth verfügbar; ggf. manuell in
#                      data/mods/ ablegen.
# =============================================================
MODRINTH_PROJECTS=geyser,floodgate


# =============================================================
# SERVER-EINSTELLUNGEN
# =============================================================

# Nachricht in der Serverliste
MOTD=Mein Minecraft Server

# Maximale Spieleranzahl
MAX_PLAYERS=20

# Schwierigkeit: peaceful  easy  normal  hard
DIFFICULTY=easy

# Standard-Spielmodus: survival  creative  adventure  spectator
GAMEMODE=survival

# Online-Modus (TRUE = nur Spieler mit Premium-Account)
# Floodgate übernimmt die Authentifizierung für Bedrock-Spieler
ONLINE_MODE=TRUE

# Spawn-Schutzradius in Blöcken (0 = deaktiviert)
SPAWN_PROTECTION=16
